{
  "name": "@evo/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/prerender.mjs",
    "preview": "vite preview",
    "lint": "yarn run -T eslint .",
    "lint:fix": "yarn run -T eslint . --fix",
    "typecheck": "tsc -b",
    "format": "yarn run -T prettier --write .",
    "format:check": "yarn run -T prettier --check .",
    "build:icons": "node scripts/generate-favicons.mjs",
    "build:og": "node scripts/generate-og-image.mjs",
    "build:assets": "yarn build:icons && yarn build:og"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "puppeteer": "^23",
    "sharp": "^0.33",
    "typescript": "~6.0.2",
    "vite": "^8.0.4"
  }
}
